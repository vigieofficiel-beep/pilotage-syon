{
  "name": "pilotage-syon",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "main": "electron.cjs",
  "description": "Logiciel de pilotage de contenu multi-plateformes",
  "author": "Lucien Doppler",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "NODE_ENV=development electron .",
    "electron:win": "set NODE_ENV=development && electron .",
    "start": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron:win\"",
    "dist": "vite build && electron-builder"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "electron-store": "^11.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1"
  },
  "build": {
    "appId": "com.syon.pilotage",
    "productName": "Pilotage Syon",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    }
  }
}
